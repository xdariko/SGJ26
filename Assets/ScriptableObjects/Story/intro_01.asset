  m_Script: {fileID: 11500000, guid: 9eae88fb23cd44843a4b2027ecc3248a, type: 3}
  m_Name: intro_01
  m_EditorClassIdentifier: Assembly-CSharp::StorySequenceData
  id: intro_01
  lines:
  - text: "\u0413\u0440\u0443\u0437\u043E\u0432\u043E\u0439 \u043A\u043E\u0440\u0430\u0431\u043B\u044C
      \u201C\u0410\u0432\u0440\u043E\u0440\u0430-9\u201D \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
      \u043B\u0435\u0442\u0435\u043B \u0447\u0435\u0440\u0435\u0437 \u043A\u043E\u0441\u043C\u043E\u0441.  "
    image: {fileID: 21300000, guid: 6b6499c31cad83140aaadbdcc1d8abaf, type: 3}
  - text: "\u042D\u043A\u0438\u043F\u0430\u0436 \u0441\u043A\u0443\u0447\u0430\u043B,
      \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u043A\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430,
      \u0430 \u0442\u0435\u0445\u043D\u0438\u043A \u0422\u0438\u043C \u043F\u0440\u043E\u0441\u0442\u043E
      \u0445\u043E\u0442\u0435\u043B \u0434\u043E\u0436\u0438\u0442\u044C \u0434\u043E
      \u043A\u043E\u043D\u0446\u0430 \u0441\u043C\u0435\u043D\u044B."
    image: {fileID: 21300000, guid: 6b6499c31cad83140aaadbdcc1d8abaf, type: 3}
  - text: "\u041F\u043E\u0442\u043E\u043C \u0432 \u043A\u043E\u0440\u0430\u0431\u043B\u044C
      \u0432\u0440\u0435\u0437\u0430\u043B\u0441\u044F \u043C\u0435\u0442\u0435\u043E\u0440\u0438\u0442."
    image: {fileID: 21300000, guid: cb737cee79b2ca74b991d366da9dce40, type: 3}
  - text: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u0432\u0441\u0435 \u043F\u043E\u0434\u0443\u043C\u0430\u043B\u0438:
      \u201C\u041D\u0443, \u0431\u044B\u0432\u0430\u0435\u0442\u201D. "
    image: {fileID: 21300000, guid: cb737cee79b2ca74b991d366da9dce40, type: 3}
  - text: "\u041F\u043E\u0442\u043E\u043C \u0438\u0437 \u043C\u0435\u0442\u0435\u043E\u0440\u0438\u0442\u0430
      \u043F\u043E\u043B\u0435\u0437\u043B\u0430 \u0436\u0438\u0432\u0430\u044F \u0441\u043B\u0438\u0437\u044C. "
    image: {fileID: 21300000, guid: cb737cee79b2ca74b991d366da9dce40, type: 3}
  - text: "\u041F\u043E\u0442\u043E\u043C \u201C\u0431\u044B\u0432\u0430\u0435\u0442\u201D
      \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B\u043E\u0441\u044C."
    image: {fileID: 0}
  - text: "\u041F\u0430\u0440\u0430\u0437\u0438\u0442 \u0431\u044B\u0441\u0442\u0440\u043E
      \u0437\u0430\u0440\u0430\u0437\u0438\u043B \u043A\u043E\u0440\u0430\u0431\u043B\u044C,
      \u044D\u043A\u0438\u043F\u0430\u0436 \u0438 \u043F\u043E\u0447\u0442\u0438
      \u0432\u0441\u0451."
    image: {fileID: 0}
  - text: "\u0422\u0438\u043C \u043F\u0440\u043E\u0441\u043D\u0443\u043B\u0441\u044F
      \u043D\u0430 \u043F\u043E\u043B\u0443 \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
      \u043E\u0442\u0441\u0435\u043A\u0430. \n\u0413\u043E\u043B\u043E\u0432\u0430
      \u0431\u043E\u043B\u0435\u043B\u0430. \u0421\u0432\u0435\u0442 \u043C\u0438\u0433\u0430\u043B.
      \n\u0413\u0434\u0435-\u0442\u043E \u0437\u0430 \u0441\u0442\u0435\u043D\u043E\u0439
      \u043A\u0442\u043E-\u0442\u043E \u043E\u0447\u0435\u043D\u044C \u043C\u043E\u043A\u0440\u043E
      \u043A\u0440\u0438\u0447\u0430\u043B."
    image: {fileID: 0}
  - text: "\u0422\u0438\u043C \u043F\u043E\u0434\u043D\u044F\u043B\u0441\u044F \u0438
      \u0441\u043A\u0430\u0437\u0430\u043B \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
      \u0440\u0430\u0437\u0443\u043C\u043D\u043E\u0435:  \n\u2014 \u042F \u0443\u0432\u043E\u043B\u044C\u043D\u044F\u044E\u0441\u044C."
    image: {fileID: 0}
  - text: "\u0423\u041F\u0420\u0410\u0412\u041B\u0415\u041D\u0418\u0415\nWASD \u2014
      \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F\nShift \u2014 \u0440\u044B\u0432\u043E\u043A\n\u041B\u041A\u041C
      \u2014 \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C\nTab \u2014 \u0438\u043D\u0432\u0435\u043D\u0442\u0430\u0440\u044C\nEsc
      \u2014 \u043F\u0430\u0443\u0437\u0430"
    image: {fileID: 0}
